{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Lumen Light Conversation Artifact",
  "type": "object",
  "required": ["artifact_id", "kind", "text", "source_turn_ids", "confidence"],
  "properties": {
    "artifact_id": {
      "type": "string",
      "pattern": "^artifact_[a-z0-9_:-]+$"
    },
    "kind": {
      "type": "string",
      "enum": ["highlight", "card", "diagram_node", "diagram_edge", "decision", "question", "action"]
    },
    "text": {
      "type": "string",
      "minLength": 1
    },
    "source_turn_ids": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "surface": {
      "type": "object",
      "properties": {
        "object_id": { "type": "string" },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "state": { "type": "string" }
      },
      "additionalProperties": false
    },
    "memory_enrichment": {
      "type": "object",
      "properties": {
        "target_systems": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "additionalProperties": false
}
