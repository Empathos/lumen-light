# Copy to .env.local and fill in. .env.local is gitignored — never commit secrets.
# The app runs without these (offline mock provider); they unlock the live
# Inworld Realtime voice/text session.

# Inworld API key (Inworld Portal -> Settings -> API Keys). Used server-side only.
INWORLD_API_KEY=your-inworld-api-key

# The LLM "brain": an Inworld router id (preferred) or a concrete model id.
# Create a router in the Inworld Portal (see README) and put its id here.
INWORLD_REALTIME_MODEL=inworld/your-router-name

# Voice + speech stack. Voice is an Inworld voice name (see Portal voice library).
INWORLD_REALTIME_VOICE=Ashley

# Optional — these have sensible defaults in code; override only if needed.
# INWORLD_STT_MODEL=inworld/inworld-stt-1
# INWORLD_TTS_MODEL=inworld-tts-2
